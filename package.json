{
	"name": "cerios-hackathon",
	"version": "0.0.0",
	"author": "Ronald Veth - Cerios",
	"private": true,
	"workspaces": ["apps/*", "packages/*"],
	"scripts": {
		"compile": "tsc --noEmit -p tsconfig.json",
		"compile:workspace": "npm run compile --workspaces --if-present",
		"db:generate": "npm run prisma:generate -w @hackaithon/database",
		"db:generate:local": "npm run prisma:generate:local -w @hackaithon/database",
		"db:push": "npm run db:push -w @hackaithon/database",
		"db:push:local": "npm run db:push:local -w @hackaithon/database",
		"db:up": "docker compose up -d postgres",
		"db:down": "docker compose down",
		"dev": "concurrently -k -n api,portal \"npm run dev:api\" \"npm run dev:portal\"",
		"dev:postgres": "npm run db:generate && npm run db:push && npm run dev",
		"dev:local": "npm run db:generate:local && npm run db:push:local && npm run dev",
		"dev:api": "npm run dev -w @hackaithon/api-learning",
		"dev:portal": "npm run dev -w @hackaithon/learner-portal",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint --type-aware apps packages",
		"lint:fix": "oxlint --type-aware --fix apps packages",
		"test": "node scripts/run-tests.mjs",
		"test:api": "node scripts/run-tests.mjs --path apps/api-learning --path packages/shared-types",
		"test:portal": "node scripts/run-tests.mjs --path apps/learner-portal --path packages/shared-types",
		"test:report": "node scripts/generate-test-report.mjs",
		"test:report:api": "node scripts/generate-test-report.mjs --path apps/api-learning --path packages/shared-types",
		"test:report:portal": "node scripts/generate-test-report.mjs --path apps/learner-portal --path packages/shared-types",
		"test:watch": "node scripts/run-tests.mjs --watch",
		"test:coverage": "node scripts/run-tests.mjs --experimental-test-coverage",
		"update-all-packages": "npm-check-updates -u && npm i"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"concurrently": "^9.2.1",
		"npm-check-updates": "^22.2.9",
		"oxfmt": "^0.53.0",
		"oxlint": "^1.68.0",
		"oxlint-tsgolint": "^0.24.0",
		"typescript": "^5.9.3"
	}
}
